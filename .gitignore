# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js legacy artifacts
/.next/
/out/

# production
/build
/public/
/db.json
/.deploy_git/

